import pytest

from src.calc import Calculator
from main import main


# --- WHITE-BOX: Calculator methods ---


def test_add_returns_sum():
    calc = Calculator()
    assert calc.add(2, 3) == 5


def test_sub_returns_difference():
    calc = Calculator()
    assert calc.sub(10, 4) == 6


def test_mul_returns_product():
    calc = Calculator()
    assert calc.mul(3, 7) == 21


def test_div_returns_division_result():
    calc = Calculator()
    assert calc.div(6, 3) == 2  


def test_div_by_zero_raises_zero_division_error():
    calc = Calculator()
    with pytest.raises(ZeroDivisionError):
        calc.div(1, 0)


# --- WHITE-BOX: main mapping + int casting + KeyError path ---


def test_main_add_prints_result(capsys):
    main("1", "+", "3")
    captured = capsys.readouterr()
    assert captured.out.strip() == "4"


def test_main_sub_prints_result(capsys):
    main("1", "-", "3")
    captured = capsys.readouterr()
    assert captured.out.strip() == "-2"


def test_main_mul_prints_result(capsys):
    main("2", "x", "3")
    captured = capsys.readouterr()
    assert captured.out.strip() == "6"


def test_main_div_prints_result_current_behavior(capsys):
    # To pokazuje aktualne zachowanie (white-box): przez "/" wynik jest float
    main("6", "/", "3")
    captured = capsys.readouterr()
    assert captured.out.strip() == "2.0"


def test_main_unknown_operator_raises_key_error():
    with pytest.raises(KeyError):
        main("1", "%", "2")


def test_main_non_integer_argument_raises_value_error():
    with pytest.raises(ValueError):
        main("1.5", "+", "2")
