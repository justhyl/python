import pytest
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC


# Zakładamy stałą bazę produktów, więc te liczby mają być stałe:
EXPECTED_COUNTS = {
    "NoteBook": 2,
    "School": 1,
    "Brand": 1,
    "Business": 1,
    "Gaming": 1,
    "Powerful": 1,
}


def _find_search_input(driver):
    # XPath-relative: szukamy inputa po placeholderze zawierającym "Szukaj"
    return WebDriverWait(driver, 10).until(
        EC.presence_of_element_located((By.XPATH, "//input[contains(@placeholder,'Szukaj')]"))
    )


def _get_visible_results_count(driver):
    # Produkty na tej stronie są zwykle w divach z klasą zawierającą "element"
    # XPath-relative:
    elements = driver.find_elements(By.XPATH, "//div[contains(@class,'element')]")
    visible = [el for el in elements if el.is_displayed()]
    return len(visible)


def search_phrase(driver, phrase):
    search_input = _find_search_input(driver)
    search_input.clear()
    search_input.send_keys(phrase)


def assert_amount(driver, phrase, expected_amount):
    expected_amount = int(expected_amount)

    search_phrase(driver, phrase)

    # Czekamy, aż liczba wyników ustabilizuje się na oczekiwanej wartości
    WebDriverWait(driver, 10).until(lambda d: _get_visible_results_count(d) == expected_amount)

    actual_amount = _get_visible_results_count(driver)
    assert actual_amount == expected_amount, (
        f"Dla frazy '{phrase}' oczekiwano {expected_amount}, ale znaleziono {actual_amount}."
    )


def assert_case_insensitive(driver, phrase):
    # sprawdzamy, że dla różnych wielkości liter jest ten sam wynik
    variants = [phrase, phrase.lower(), phrase.upper()]
    counts = []

    for v in variants:
        search_phrase(driver, v)
        # czekamy aż cokolwiek się policzy (nie zawsze znamy liczbę tutaj)
        WebDriverWait(driver, 10).until(lambda d: _get_visible_results_count(d) >= 0)
        counts.append(_get_visible_results_count(driver))

    assert counts[0] == counts[1] == counts[2], (
        f"Wyszukiwarka nie jest case-insensitive dla '{phrase}'. "
        f"Wyniki: {variants} -> {counts}"
    )


@pytest.mark.parametrize("phrase,expected", EXPECTED_COUNTS.items())
def test_store_search_amounts_and_case_insensitive(selenium, phrase, expected):
    driver = selenium
    driver.get("https://kodilla.com/pl/test/store")

    # 1) weryfikacja liczby wyników (wymaganie funkcjonalne)
    assert_amount(driver, phrase, expected)

    # 2) weryfikacja ignorowania wielkości znaków
    assert_case_insensitive(driver, phrase)
