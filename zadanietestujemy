import os
import time
import uuid

import pytest
import requests


# Ustaw w shellu np:
# export API_BASE_URL="http://localhost:5000"
BASE_URL = os.getenv("API_BASE_URL", "http://localhost:5000").rstrip("/")

ARTICLES_URL = f"{BASE_URL}/articles"


def unique_title(prefix="Article X"):
    # proste, czytelne, unikalne
    return f"{prefix} - {int(time.time())} - {uuid.uuid4().hex[:8]}"


def get_articles():
    resp = requests.get(ARTICLES_URL, timeout=10)
    return resp


def get_articles_json():
    resp = get_articles()
    resp.raise_for_status()
    data = resp.json()
    # Zakładamy, że API zwraca listę artykułów
    if not isinstance(data, list):
        raise AssertionError(f"Expected list, got: {type(data)} / {data}")
    return data


def extract_titles(articles):
    # Zakładamy, że każdy artykuł ma pole "title"
    return [a.get("title") for a in articles]


def add_article(payload):
    resp = requests.post(ARTICLES_URL, json=payload, timeout=10)
    return resp


def delete_article(article_id):
    resp = requests.delete(f"{ARTICLES_URL}/{article_id}", timeout=10)
    return resp


def find_article_by_title(articles, title):
    for a in articles:
        if a.get("title") == title:
            return a
    return None


@pytest.fixture
def created_article_id():
    """
    Fixture pomocnicza: jeśli w teście stworzymy artykuł, to na końcu spróbujemy go sprzątnąć.
    Używamy go ręcznie (yield id), bo w scenariuszu #2 chcemy kontrolować kolejność.
