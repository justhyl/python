def is_palindrome(data):

    # sprawdzamy czy argument jest None
    if data is None:
        raise TypeError("Argument nie może być None")

    # jeśli to liczba całkowita
    if isinstance(data, int):
        if data < 0:
            return False
        data = str(data)

    # jeśli to liczba zmiennoprzecinkowa
    if isinstance(data, float):
        if data < 0:
            return False
        data = str(data)

    # jeśli to napis
    if isinstance(data, str):
        cleaned = ""

        # usuwamy spacje i znaki specjalne
        for char in data:
            if char.isalnum():
                cleaned = cleaned + char.lower()

        reversed_text = cleaned[::-1]

        if cleaned == reversed_text:
            return True
        else:
            return False

    # jeśli to lista
    if isinstance(data, list):
        if data == data[::-1]:
            return True
        else:
            return False

    # jeśli to krotka
    if isinstance(data, tuple):
        if data == data[::-1]:
            return True
        else:
            return False

    # inne typy danych
    raise TypeError("Nieobsługiwany typ danych")

def test_simple_word():
    assert is_palindrome("kajak") == True


def test_not_palindrome():
    assert is_palindrome("python") == False


def test_sentence():
    assert is_palindrome("Kobyła ma mały bok.") == True


def test_integer():
    assert is_palindrome(121) == True


def test_negative_number():
    assert is_palindrome(-121) == False


def test_list():
    assert is_palindrome([1, 2, 3, 2, 1]) == True


def test_empty_string():
    assert is_palindrome("") == True
