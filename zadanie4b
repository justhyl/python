def test_cli_with_zero_arguments_returns_error():
    # aktualnie main(*args) wywali się TypeError przy braku argumentów
    result = run_app()

    assert result.returncode != 0
    # w tej wersji to raczej traceback, ale przynajmniej wykrywamy błąd wejścia
    assert result.stdout.strip() == ""


def test_cli_with_too_few_arguments_returns_error():
    result = run_app("1", "+")  # brakuje right
    assert result.returncode != 0
    assert result.stdout.strip() == ""


def test_cli_with_too_many_arguments_returns_error():
    result = run_app("1", "+", "2", "3")  # za dużo argumentów
    assert result.returncode != 0
    assert result.stdout.strip() == ""


def test_cli_with_non_numeric_argument_returns_error():
    result = run_app("aaa", "+", "2")
    assert result.returncode != 0
    assert result.stdout.strip() == ""


def test_cli_with_float_string_argument_returns_error():
    result = run_app("1.5", "+", "2")
    assert result.returncode != 0
    assert result.stdout.strip() == ""


def test_cli_with_unknown_operator_returns_error():
    result = run_app("1", "%", "2")
    assert result.returncode != 0
    assert result.stdout.strip() == ""


