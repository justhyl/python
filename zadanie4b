import subprocess
import sys
from pathlib import Path

import pytest

PROJECT_ROOT = Path(__file__).resolve().parents[1]
MAIN_FILE = PROJECT_ROOT / "main.py"


def run_app(*args: str) -> subprocess.CompletedProcess:
    # uruchamiamy jak user: python main.py <args...>
    cmd = [sys.executable, str(MAIN_FILE), *args]
    return subprocess.run(cmd, capture_output=True, text=True)


# --- BLACK-BOX: wymagania funkcjonalne (happy path) ---


@pytest.mark.parametrize(
    "left,op,right,expected",
    [
        ("1", "+", "3", "4"),
        ("1", "-", "3", "-2"),
        ("2", "x", "3", "6"),
    ],
)
def test_cli_operations_ok(left, op, right, expected):
    result = run_app(left, op, right)

    assert result.returncode == 0
    assert result.stderr.strip() == ""
    assert result.stdout.strip() == expected


@pytest.mark.xfail(reason="BUG: README expects integer output '2', but app prints '2.0' for division")
def test_cli_division_should_print_integer_as_in_readme():
    # README pokazuje 6 / 3 -> 2 (bez .0) :contentReference[oaicite:3]{index=3}
    result = run_app("6", "/", "3")

    assert result.returncode == 0
    assert result.stderr.strip() == ""
    assert result.stdout.strip() == "2"


