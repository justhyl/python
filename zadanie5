import pytest
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC


def test_search_laptop(selenium):
    driver = selenium
    driver.get("https://www.ebay.com/")

    # Znajdź pole wyszukiwania
    search_input = driver.find_element(By.ID, "gh-ac")

    # Wpisz "Laptop"
    search_input.clear()
    search_input.send_keys("Laptop")

    # Zatwierdź wyszukiwanie
    search_input.send_keys(Keys.RETURN)

    # Czekamy aż załadują się wyniki
    WebDriverWait(driver, 10).until(
        EC.presence_of_element_located((By.CSS_SELECTOR, "h1.srp-controls__count-heading"))
    )

    # Asercja - sprawdzamy czy w nagłówku strony jest słowo Laptop
    header = driver.find_element(By.CSS_SELECTOR, "h1.srp-controls__count-heading")
    assert "laptop" in header.text.lower()

    # Alternatywna asercja - sprawdzenie kategorii po lewej
    category = driver.find_element(By.PARTIAL_LINK_TEXT, "Laptops & Netbooks")
    assert category.is_displayed()

def test_product_availability(selenium):
    driver = selenium
    driver.get("https://www.ebay.com/")

    # Wyszukaj Laptop
    search_input = driver.find_element(By.ID, "gh-ac")
    search_input.send_keys("Laptop")
    search_input.send_keys(Keys.RETURN)

    # Poczekaj na listę produktów
    WebDriverWait(driver, 10).until(
        EC.presence_of_element_located((By.CSS_SELECTOR, "li.s-item"))
    )

    # Kliknij pierwszy produkt z listy
    first_product = driver.find_element(By.CSS_SELECTOR, "li.s-item a.s-item__link")
    first_product.click()

    # Poczekaj aż strona produktu się załaduje
    WebDriverWait(driver, 10).until(
        EC.presence_of_element_located((By.ID, "qtySubTxt"))
    )

    availability_text = driver.find_element(By.ID, "qtySubTxt").text

    # Sprawdzamy czy informacja o dostępności istnieje
    assert "available" in availability_text.lower()
